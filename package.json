{
  "name": "@tangoman75/pivot",
  "version": "0.1.0",
  "description": "Pico Framework extension",
  "author": "Matthias Morin",
  "main": "css/pivot.min.css",
  "homepage": "https://tangoman.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TangoMan75/pivot.git"
  },
  "keywords": [
    "css",
    "css-framework",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "minimalist",
    "minimalistic",
    "native-html",
    "scss-framework",
    "semantic"
  ],
  "bugs": {
    "url": "https://github.com/TangoMan75/pivot/issues"
  },
  "scripts": {
    "✨": "run-s build",
    "build": "run-s start lint \"build:*\" done --silent",
    "watch": "nodemon -q --watch ./src/scss/ --ext scss --exec 'run-s build'",
    "lint": "run-s \"lint:*\" --silent",
    "lint:js": "# eslint src/**/*.js",
    "lint:prettier": "prettier --write --log-level silent './src/scss/**/*.scss'",
    "lint:sort-scss": "postcss ./src/scss/**/*.scss --replace",
    "build:js": "# babel ./src/js --out-dir ./dist --extensions .js",
    "build:css": "sass --no-source-map --style expanded --no-error-css ./src/scss/:./dist/css/",
    "build:autoprefix": "postcss --config css --replace ./dist/css/*.css !./dist/css/*.min.css",
    "build:minify": "cleancss -O1 --with-rebase --batch --batch-suffix .min ./dist/css/*.css !./dist/css/*.min.css",
    "test": "jest",
    "prelint": "echo '[@tangoman75/pivot] ✨ Lint'",
    "prelint:js": "echo '[@tangoman75/pivot] ✨ Lint JS'",
    "pretest": "echo '[@tangoman75/pivot] ✨ Test'",
    "prebuild:css": "echo '[@tangoman75/pivot] ✨ Compile'",
    "prebuild:autoprefix": "echo '[@tangoman75/pivot] ✨ Autoprefix'",
    "prebuild:minify": "echo '[@tangoman75/pivot] ✨ Minify'",
    "start": "echo '\\033[96m[@tangoman75/pivot] ✨ Start\\033[0m'",
    "done": "echo '\\033[32m[@tangoman75/pivot] ✨ Done\\033[0m'"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.10",
    "@babel/node": "^7.26.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@babel/runtime": "^7.26.10",
    "@eslint/js": "^9.22.0",
    "@types/jest": "^29.5.14",
    "autoprefixer": "^10.4.21",
    "babel-cli": "^6.26.0",
    "caniuse-lite": "^1.0.30001703",
    "clean-css-cli": "^5.6.3",
    "css-declaration-sorter": "^7.2.0",
    "eslint": "^9.22.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "ts-jest": "^29.2.6"
  },
  "browserslist": [
    "defaults"
  ]
}
